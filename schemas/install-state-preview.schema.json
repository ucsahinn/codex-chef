{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Codex Enterprise Starter install-state preview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "dryRunOnly",
    "source",
    "target",
    "options",
    "selectedComponentIds",
    "skippedComponentIds",
    "operations"
  ],
  "properties": {
    "schemaVersion": {
      "const": "codex-enterprise-starter.install-state-preview.v1"
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "dryRunOnly": {
      "const": true
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageName", "packageVersion", "manifest", "manifestVersion"],
      "properties": {
        "packageName": {
          "type": "string",
          "minLength": 1
        },
        "packageVersion": {
          "type": "string",
          "minLength": 1
        },
        "manifest": {
          "const": "manifests/install-plan.json"
        },
        "manifestVersion": {
          "const": "codex-enterprise-starter.install-plan.v1"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "codexHome", "agentsHome", "home"],
      "properties": {
        "platform": {
          "enum": ["windows", "unix"]
        },
        "codexHome": {
          "type": "string",
          "minLength": 1
        },
        "agentsHome": {
          "type": "string",
          "minLength": 1
        },
        "home": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all", "installSkills", "installGitGuards", "force", "noBackup", "redactPaths"],
      "properties": {
        "all": {
          "type": "boolean"
        },
        "installSkills": {
          "type": "boolean"
        },
        "installGitGuards": {
          "type": "boolean"
        },
        "force": {
          "type": "boolean"
        },
        "noBackup": {
          "type": "boolean"
        },
        "redactPaths": {
          "type": "boolean"
        }
      }
    },
    "selectedComponentIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skippedComponentIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "componentId",
          "kind",
          "summary",
          "risk",
          "collision",
          "conflictPolicy",
          "backup",
          "force",
          "wouldMutateGlobalState",
          "selectedBy"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "componentId": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": ["copy-file", "copy-directory", "write-marketplace", "git-config", "skill-install"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "risk": {
            "enum": ["low", "medium", "high"]
          },
          "collision": {
            "type": "string",
            "minLength": 1
          },
          "conflictPolicy": {
            "type": "string",
            "minLength": 1
          },
          "backup": {
            "type": "boolean"
          },
          "force": {
            "type": "boolean"
          },
          "wouldMutateGlobalState": {
            "const": true
          },
          "selectedBy": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
