# Curated global approval rules.
# Keep this file general-purpose. Project-specific, release, publishing,
# credential, and destructive operations must remain interactive.

# Fast, read-only discovery.
prefix_rule(pattern = ["rg"], decision = "allow")
prefix_rule(pattern = ["rg", "--files"], decision = "allow")
prefix_rule(pattern = ["Get-ChildItem"], decision = "allow")
prefix_rule(pattern = ["Get-Content"], decision = "allow")
prefix_rule(pattern = ["Select-String"], decision = "allow")
prefix_rule(pattern = ["Select-Object"], decision = "allow")
prefix_rule(pattern = ["Get-Command"], decision = "allow")
prefix_rule(pattern = ["Get-Process"], decision = "allow")
prefix_rule(pattern = ["Test-Path"], decision = "allow")
prefix_rule(pattern = ["Where-Object"], decision = "allow")
prefix_rule(pattern = ["ForEach-Object"], decision = "allow")
prefix_rule(pattern = ["Get-FileHash"], decision = "allow")
prefix_rule(pattern = ["Get-AuthenticodeSignature"], decision = "allow")
prefix_rule(pattern = ["where.exe"], decision = "allow")
prefix_rule(pattern = ["Test-NetConnection"], decision = "allow")
prefix_rule(pattern = ["netstat", "-ano"], decision = "allow")

# Extra harmless PowerShell inspection and formatting helpers.
prefix_rule(pattern = ["Get-Item"], decision = "allow")
prefix_rule(pattern = ["Resolve-Path"], decision = "allow")
prefix_rule(pattern = ["Get-Location"], decision = "allow")
prefix_rule(pattern = ["Split-Path"], decision = "allow")
prefix_rule(pattern = ["Join-Path"], decision = "allow")
prefix_rule(pattern = ["Sort-Object"], decision = "allow")
prefix_rule(pattern = ["Measure-Object"], decision = "allow")
prefix_rule(pattern = ["Format-Table"], decision = "allow")
prefix_rule(pattern = ["Format-List"], decision = "allow")
prefix_rule(pattern = ["Out-String"], decision = "allow")
prefix_rule(pattern = ["ConvertFrom-Json"], decision = "allow")
prefix_rule(pattern = ["ConvertTo-Json"], decision = "allow")

# Common read-only PowerShell commands when Codex invokes PowerShell explicitly.
prefix_rule(pattern = ["powershell.exe", "-Command", "Get-Content"], decision = "allow")
prefix_rule(pattern = ["powershell.exe", "-Command", "Get-ChildItem"], decision = "allow")
