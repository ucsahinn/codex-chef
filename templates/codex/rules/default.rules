prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Get-ChildItem"], decision = "allow")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Select-String"], decision = "allow")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Select-Object"], decision = "allow")
