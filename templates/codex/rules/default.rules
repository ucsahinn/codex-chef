# Explicit PowerShell-wrapper prompts for destructive, process, network, and overwrite-prone actions.
prefix_rule(pattern = ["powershell.exe", "-Command", "Remove-Item"], decision = "prompt", justification = "Deletion and destructive file operations require explicit user approval.")
prefix_rule(pattern = ["powershell.exe", "-Command", "rm"], decision = "prompt", justification = "Deletion and destructive file operations require explicit user approval.")
prefix_rule(pattern = ["powershell.exe", "-Command", "del"], decision = "prompt", justification = "Deletion and destructive file operations require explicit user approval.")
prefix_rule(pattern = ["powershell.exe", "-Command", "Move-Item"], decision = "prompt", justification = "Moving or renaming files outside a scoped edit requires approval.")
prefix_rule(pattern = ["powershell.exe", "-Command", "Copy-Item"], decision = "prompt", justification = "Copy operations can overwrite or exfiltrate files and require approval.")
prefix_rule(pattern = ["powershell.exe", "-Command", "Set-Content"], decision = "prompt", justification = "Shell writes can overwrite files and require approval unless handled through the edit tool.")
prefix_rule(pattern = ["powershell.exe", "-Command", "Add-Content"], decision = "prompt", justification = "Shell writes can modify files and require approval unless handled through the edit tool.")
prefix_rule(pattern = ["powershell.exe", "-Command", "Out-File"], decision = "prompt", justification = "Shell writes can overwrite files and require approval unless handled through the edit tool.")
prefix_rule(pattern = ["powershell.exe", "-Command", "Start-Process"], decision = "prompt", justification = "Starting GUI, elevated, installer, or long-running processes requires approval unless an exact safe rule exists.")
prefix_rule(pattern = ["powershell.exe", "-Command", "Stop-Process"], decision = "prompt", justification = "Stopping processes can disrupt user work and requires approval.")
prefix_rule(pattern = ["powershell.exe", "-Command", "Invoke-WebRequest"], decision = "prompt", justification = "Network requests require approval unless they run inside the active sandbox policy.")
prefix_rule(pattern = ["powershell.exe", "-Command", "Invoke-RestMethod"], decision = "prompt", justification = "Network requests require approval unless they run inside the active sandbox policy.")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Remove-Item"], decision = "prompt", justification = "Deletion and destructive file operations require explicit user approval.")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "rm"], decision = "prompt", justification = "Deletion and destructive file operations require explicit user approval.")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "del"], decision = "prompt", justification = "Deletion and destructive file operations require explicit user approval.")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Move-Item"], decision = "prompt", justification = "Moving or renaming files outside a scoped edit requires approval.")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Copy-Item"], decision = "prompt", justification = "Copy operations can overwrite or exfiltrate files and require approval.")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Set-Content"], decision = "prompt", justification = "Shell writes can overwrite files and require approval unless handled through the edit tool.")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Add-Content"], decision = "prompt", justification = "Shell writes can modify files and require approval unless handled through the edit tool.")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Out-File"], decision = "prompt", justification = "Shell writes can overwrite files and require approval unless handled through the edit tool.")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Start-Process"], decision = "prompt", justification = "Starting GUI, elevated, installer, or long-running processes requires approval unless an exact safe rule exists.")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Stop-Process"], decision = "prompt", justification = "Stopping processes can disrupt user work and requires approval.")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Invoke-WebRequest"], decision = "prompt", justification = "Network requests require approval unless they run inside the active sandbox policy.")
prefix_rule(pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Invoke-RestMethod"], decision = "prompt", justification = "Network requests require approval unless they run inside the active sandbox policy.")

