prefix_rule(pattern = ["gh", "release", "view"], decision = "allow")
prefix_rule(pattern = ["gh", "workflow", "list"], decision = "allow")
prefix_rule(pattern = ["gh", "workflow", "view"], decision = "allow")

# Always keep irreversible, external-write, credential, or broad shell operations interactive.
# Deletion/removal/cleanup operations must ask first; non-destructive work may continue.
prefix_rule(pattern = ["Remove-Item"], decision = "prompt", justification = "Deletion and destructive file operations require explicit user approval.")
prefix_rule(pattern = ["Move-Item"], decision = "prompt", justification = "Moving or renaming files outside a scoped edit requires approval.")
prefix_rule(pattern = ["Copy-Item"], decision = "prompt", justification = "Copy operations can overwrite or exfiltrate files and require approval.")
prefix_rule(pattern = ["rm"], decision = "prompt", justification = "Deletion and destructive file operations require explicit user approval.")
prefix_rule(pattern = ["del"], decision = "prompt", justification = "Deletion and destructive file operations require explicit user approval.")
prefix_rule(pattern = ["git", "add", "."], decision = "prompt", justification = "Stage explicit files after reviewing the diff; avoid blanket staging.")
prefix_rule(pattern = ["git", "commit"], decision = "prompt", justification = "Commits should only be created when the user requests them.")
prefix_rule(pattern = ["git", "push"], decision = "prompt", justification = "Pushing changes must remain an explicit user decision.")
prefix_rule(pattern = ["git", "reset"], decision = "prompt", justification = "Reset can discard work and requires approval.")
prefix_rule(pattern = ["git", "checkout"], decision = "prompt", justification = "Checkout can overwrite local changes and requires approval.")
prefix_rule(pattern = ["git", "restore"], decision = "prompt", justification = "Restore can discard work and requires approval.")
prefix_rule(pattern = ["npm.cmd", "install"], decision = "prompt", justification = "Dependency changes require explicit approval.")
prefix_rule(pattern = ["npm.cmd", "uninstall"], decision = "prompt", justification = "Uninstalling dependencies requires explicit user approval.")
prefix_rule(pattern = ["npm.cmd", "run", "clean"], decision = "prompt", justification = "Cleanup scripts can delete build outputs, caches, or local state and require approval.")
prefix_rule(pattern = ["npm", "run", "clean"], decision = "prompt", justification = "Cleanup scripts can delete build outputs, caches, or local state and require approval.")
prefix_rule(pattern = ["npm.cmd", "publish"], decision = "prompt", justification = "Publishing packages requires explicit approval.")
prefix_rule(pattern = ["npx.cmd", "skills", "add"], decision = "prompt", justification = "Installing global skills changes the agent instruction supply chain and requires approval.")
prefix_rule(pattern = ["curl"], decision = "prompt", justification = "Network requests require approval unless they run inside the active sandbox policy.")
prefix_rule(pattern = ["Invoke-RestMethod"], decision = "prompt", justification = "Network requests require approval unless they run inside the active sandbox policy.")
prefix_rule(pattern = ["Invoke-WebRequest"], decision = "prompt", justification = "Network requests require approval unless they run inside the active sandbox policy.")

