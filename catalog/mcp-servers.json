{
  "version": "0.1.0",
  "dateChecked": "2026-06-14",
  "sourcePolicy": "Authenticated account, database, and broad filesystem connectors stay disabled by default. Each server records sourceUrl, risk, auth, approval, and why it is enabled or disabled.",
  "servers": [
    {
      "name": "openaiDeveloperDocs",
      "category": "documentation",
      "transport": "streamable_http",
      "defaultEnabled": true,
      "url": "https://developers.openai.com/mcp",
      "auth": "none",
      "approval": "approve",
      "risk": "low",
      "sourceUrl": "https://developers.openai.com/mcp",
      "defaultReason": "Official read-only documentation source.",
      "notes": "Official OpenAI developer documentation."
    },
    {
      "name": "context7",
      "category": "documentation",
      "transport": "stdio",
      "defaultEnabled": true,
      "package": "@upstash/context7-mcp",
      "auth": "none",
      "approval": "approve",
      "risk": "low",
      "sourceUrl": "https://github.com/upstash/context7",
      "defaultReason": "Documentation lookup only; no project mutation.",
      "notes": "Current library and framework docs."
    },
    {
      "name": "sequential-thinking",
      "category": "reasoning",
      "transport": "stdio",
      "defaultEnabled": true,
      "package": "@modelcontextprotocol/server-sequential-thinking",
      "auth": "none",
      "approval": "prompt",
      "risk": "low",
      "sourceUrl": "https://github.com/modelcontextprotocol/servers",
      "defaultReason": "Reasoning helper with prompted tool approval.",
      "notes": "Structured decomposition helper."
    },
    {
      "name": "playwright",
      "category": "browser",
      "transport": "stdio",
      "defaultEnabled": true,
      "package": "@playwright/mcp@latest",
      "auth": "none",
      "approval": "prompt",
      "risk": "medium",
      "sourceUrl": "https://github.com/microsoft/playwright-mcp",
      "defaultReason": "Useful for UI evidence; browser actions must prompt.",
      "notes": "Browser automation and UI verification."
    },
    {
      "name": "chrome-devtools",
      "category": "browser",
      "transport": "stdio",
      "defaultEnabled": true,
      "package": "chrome-devtools-mcp@latest",
      "auth": "none",
      "approval": "prompt",
      "risk": "medium",
      "sourceUrl": "https://github.com/ChromeDevTools/chrome-devtools-mcp",
      "defaultReason": "Browser inspection only with isolated mode and redacted headers.",
      "notes": "Chrome inspection with isolated mode and redacted network headers."
    },
    {
      "name": "serena",
      "category": "code-intelligence",
      "transport": "stdio",
      "defaultEnabled": true,
      "command": "uvx",
      "auth": "none",
      "approval": "prompt",
      "risk": "medium",
      "sourceUrl": "https://github.com/oraios/serena",
      "defaultReason": "Semantic local code navigation; prompts before write-capable tools.",
      "notes": "Semantic code navigation. Disable if uvx is unavailable."
    },
    {
      "name": "memory",
      "category": "local-state",
      "transport": "stdio",
      "defaultEnabled": true,
      "package": "@modelcontextprotocol/server-memory",
      "auth": "none",
      "approval": "prompt",
      "risk": "medium",
      "sourceUrl": "https://github.com/modelcontextprotocol/servers",
      "defaultReason": "Local memory can be useful but must not store secrets.",
      "notes": "Local memory graph. Do not store secrets."
    },
    {
      "name": "filesystem",
      "category": "filesystem",
      "transport": "stdio",
      "defaultEnabled": false,
      "package": "@modelcontextprotocol/server-filesystem",
      "auth": "none",
      "approval": "prompt",
      "risk": "high",
      "sourceUrl": "https://github.com/modelcontextprotocol/servers",
      "defaultReason": "Disabled because broad filesystem access is too powerful for a starter default.",
      "notes": "Enable only for intentional local paths."
    },
    {
      "name": "github",
      "category": "external-account",
      "transport": "streamable_http",
      "defaultEnabled": false,
      "url": "https://api.githubcopilot.com/mcp/readonly",
      "auth": "oauth",
      "approval": "prompt",
      "risk": "high",
      "sourceUrl": "https://docs.github.com/en/copilot",
      "defaultReason": "Disabled because it requires account authorization.",
      "notes": "Repository and PR context. Keep disabled until needed."
    },
    {
      "name": "figma",
      "category": "external-account",
      "transport": "streamable_http",
      "defaultEnabled": false,
      "url": "https://mcp.figma.com/mcp",
      "auth": "oauth",
      "approval": "prompt",
      "risk": "high",
      "sourceUrl": "https://help.figma.com",
      "defaultReason": "Disabled because it requires private design-account authorization.",
      "notes": "Design context. Requires user or workspace auth."
    },
    {
      "name": "linear",
      "category": "external-account",
      "transport": "streamable_http",
      "defaultEnabled": false,
      "url": "https://mcp.linear.app/mcp",
      "auth": "oauth",
      "approval": "prompt",
      "risk": "high",
      "sourceUrl": "https://linear.app/docs",
      "defaultReason": "Disabled because it can expose private issue/project data.",
      "notes": "Issue and project workflows."
    },
    {
      "name": "notion",
      "category": "external-account",
      "transport": "streamable_http",
      "defaultEnabled": false,
      "url": "https://mcp.notion.com/mcp",
      "auth": "oauth",
      "approval": "prompt",
      "risk": "high",
      "sourceUrl": "https://developers.notion.com",
      "defaultReason": "Disabled because it can expose private workspace docs and databases.",
      "notes": "Private docs and databases."
    },
    {
      "name": "sentry",
      "category": "external-account",
      "transport": "streamable_http",
      "defaultEnabled": false,
      "url": "https://mcp.sentry.dev/mcp",
      "auth": "oauth",
      "approval": "prompt",
      "risk": "high",
      "sourceUrl": "https://docs.sentry.io",
      "defaultReason": "Disabled because it can expose production error data.",
      "notes": "Production errors and operational telemetry."
    },
    {
      "name": "vercel",
      "category": "external-account",
      "transport": "streamable_http",
      "defaultEnabled": false,
      "url": "https://mcp.vercel.com",
      "auth": "oauth",
      "approval": "prompt",
      "risk": "high",
      "sourceUrl": "https://vercel.com/docs",
      "defaultReason": "Disabled because it can expose project and deployment data.",
      "notes": "Project, deployment, and platform data."
    },
    {
      "name": "supabase",
      "category": "database",
      "transport": "stdio",
      "defaultEnabled": false,
      "package": "@modelcontextprotocol/server-postgres",
      "auth": "env:SUPABASE_DB_URL",
      "approval": "prompt",
      "risk": "critical",
      "sourceUrl": "https://github.com/modelcontextprotocol/servers",
      "defaultReason": "Disabled because database access must be task-specific and explicit.",
      "notes": "Database access. Enable only with explicit task need."
    }
  ]
}
